# ==============================================================================
# 1. CONFIGURAÇÕES DO BANCO DE DADOS (POSTGRESQL 18.3)
# ==============================================================================
# Usuário e senha que o container do Postgres criará no boot inicial
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=n8n_production

# ==============================================================================
# 2. CONFIGURAÇÕES DE SEGURANÇA E ENCRIPTAÇÃO DO N8N
# ==============================================================================
# Chave usada para criptografar suas credenciais no banco.
# DICA: Gere uma nova com: openssl rand -hex 24
N8N_ENCRYPTION_KEY=8f3a2c5e1b9d4f0a7c7a4b4a3d2f1e0c9b8a7d6c5b4a3d2

# Define quem pode acessar a API do n8n via browser (Essencial para seu React no SWA)
# Substitua pela URL que a Azure gerou para o seu Static Web App
# REACT_SWA_URL=https://white-sea-0123456.azurestaticapps.net

# ==============================================================================
# 3. ACESSO E NETWORKING (WEBHOOKS)
# ==============================================================================
# A URL pública onde o n8n estará acessível. Sem isso, Webhooks e OAuth não funcionam.
# Use o IP Estático que você configurou no Portal da Azure.
WEBHOOK_URL=https://localhost:5678/
N8N_SECURE_COOKIE=true

# ==============================================================================
# 4. PERFORMANCE E EXECUÇÃO (OTIMIZAÇÃO 2026)
# ==============================================================================
# 4.1 RUNNERS
# ==============================================================================
# Modo externo garante que o processo principal não trave em workflows pesados
N8N_RUNNERS_ENABLED=false
N8N_RUNNERS_MODE=internal
N8N_RUNNERS_AUTH_TOKEN=c9f6c259d6c61c166dec897a3476bc11ed79245460aa318a

# Fuso horário para agendamentos funcionarem corretamente no horário de Brasília
GENERIC_TIMEZONE=America/Sao_Paulo